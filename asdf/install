#!/usr/bin/env ruby

# Install Homebrew if not present
unless system("which brew > /dev/null 2>&1")
  puts " * Installing Homebrew..."
  system('/bin/bash -c "$(curl -fsSL https://raw.githubusercontent.com/Homebrew/install/HEAD/install.sh)"')
  # Add brew to PATH for the rest of this script
  system('eval "$(/opt/homebrew/bin/brew shellenv)"')
end

# Link .tool-versions to home directory
link("asdf/tool-versions")

# Install brew packages
%w[asdf zoxide fzf ripgrep eza git-lfs].each do |pkg|
  unless system("brew list #{pkg} > /dev/null 2>&1")
    puts " * Installing #{pkg}..."
    system("brew install #{pkg}")
  end
end

# Add plugins (idempotent – will skip if already installed)
plugins = %w[nodejs ruby bun yarn]
plugins.each do |plugin|
  system("asdf plugin add #{plugin} 2>/dev/null")
  puts " * asdf plugin: #{plugin}"
end

# Install all versions from .tool-versions
puts " * Installing tool versions (this may take a while)..."
system("asdf install")

# Enable corepack and activate pnpm
puts " * Enabling corepack + pnpm..."
system("corepack enable")
system("corepack install -g pnpm@latest")
