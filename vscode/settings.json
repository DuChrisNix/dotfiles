{
  "editor.accessibilitySupport": "off",
  "editor.fontFamily": "FiraCode Nerd Font Mono",
  "editor.fontSize": 16,
  "security.workspace.trust.untrustedFiles": "open",
  "workbench.iconTheme": "material-icon-theme",
  "colorize.languages": [
    "css",
    "sass",
    "scss",
    "less",
    "postcss",
    "sss",
    "stylus",
    "xml",
    "svg",
    "yaml",
    "json",
  ],
  "svelte.enable-ts-plugin": true,
  "workbench.tree.indent": 16,
  "editor.tabSize": 2,
  "workbench.editor.labelFormat": "short",
  "workbench.colorTheme": "Ayu Dark",
  "editor.cursorSmoothCaretAnimation": "on",
  "editor.cursorBlinking": "smooth",
  "editor.cursorStyle": "block",
  "workbench.colorCustomizations": {
    "editorCursor.foreground": "#edb54b",
    "editorBracketHighlight.foreground1": "#33859d",
    "editorBracketHighlight.foreground2": "#edb54b",
    "editorBracketHighlight.foreground3": "#218d76",
    "editorBracketHighlight.foreground4": "#6e70a9",
    "editorBracketHighlight.foreground5": "#d26939",
    "editorBracketHighlight.foreground6": "#c33027",
  },
  "editor.fontLigatures": true,
  "[typescript]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "javascript.updateImportsOnFileMove.enabled": "always",
  "terminal.integrated.env.osx": {
    "FIG_NEW_SESSION": "1",
  },
  "redhat.telemetry.enabled": true,
  "emmet.syntaxProfiles": {
    "svelte": "html",
  },
  "emmet.includeLanguages": {
    "svelte": "html",
  },
  "editor.indentSize": "tabSize",
  "svelte.plugin.html.completions.emmet": true,
  "[typescriptreact]": {
    "editor.defaultFormatter": "esbenp.prettier-vscode",
  },
  "colorize.hide_current_line_decorations": false,
  "[json]": {
    "editor.defaultFormatter": "vscode.json-language-features",
  },
  "editor.unicodeHighlight.ambiguousCharacters": false,
  "yaml.customTags": [
    "!And",
    "!And sequence",
    "!If",
    "!If sequence",
    "!Not",
    "!Not sequence",
    "!Equals",
    "!Equals sequence",
    "!Or",
    "!Or sequence",
    "!FindInMap",
    "!FindInMap sequence",
    "!Base64",
    "!Join",
    "!Join sequence",
    "!Cidr",
    "!Ref",
    "!Sub",
    "!Sub sequence",
    "!GetAtt",
    "!GetAZs",
    "!ImportValue",
    "!ImportValue sequence",
    "!Select",
    "!Select sequence",
    "!Split",
    "!Split sequence",
  ],
  "cSpell.userWords": ["pickable", "Soulforge", "stylesheet", "svgs"],
  "editor.defaultFormatter": "esbenp.prettier-vscode",
  "[svelte]": {
    "editor.defaultFormatter": "svelte.svelte-vscode",
  },
  "svelte.plugin.svelte.defaultScriptLanguage": "ts",
  "svelte.plugin.svelte.format.config.svelteBracketNewLine": false,
  "[ruby]": {
    "editor.defaultFormatter": "misogi.ruby-rubocop",
  },
  "diffEditor.ignoreTrimWhitespace": false,
  "typescript.updateImportsOnFileMove.enabled": "always",
  "extensions.ignoreRecommendations": true,
  "github.copilot.editor.enableAutoCompletions": true,
  "supermaven.enable": {
    "plaintext": false,
  },
  "[astro]": {
    "editor.defaultFormatter": "astro-build.astro-vscode",
  },
  "git.autofetch": true,
  "explorer.confirmDragAndDrop": false,
  "explorer.confirmPasteNative": false,
  "typescript.preferences.organizeImports": {},
  "editor.codeLensFontFamily": "FiraCode Nerd Font Mono",
  "gitlens.currentLine.fontFamily": "FiraCode Nerd Font Mono",
  "[dockercompose]": {
    "editor.insertSpaces": true,
    "editor.tabSize": 2,
    "editor.autoIndent": "advanced",
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "[github-actions-workflow]": {
    "editor.defaultFormatter": "redhat.vscode-yaml",
  },
  "git.confirmSync": false,
  "[erb]": {
    "editor.defaultFormatter": "Shopify.ruby-lsp",
  },
  "editor.formatOnSave": true,
}
